# Local Configuration
# This file contains environment variables for running the RAG demo locally
# Copy this file to .env and fill in your actual credentials

# ============================================
# Mode Configuration
# ============================================
# Set to false for local development (no AWS required)
USE_S3_UPLOAD=false
USE_SSM_CONFIG=false

# ============================================
# Azure OpenAI Configuration (Required)
# ============================================
# Get these from: https://portal.azure.com → Azure OpenAI resource

# Primary endpoint for chat/completions
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Embedding endpoint (can be same as above)
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=your-api-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Optional: Failover endpoint (secondary Azure OpenAI)
# AZURE_OPENAI_FAILOVER_ENDPOINT=https://your-failover-resource.openai.azure.com/
# AZURE_OPENAI_FAILOVER_API_KEY=your-failover-key-here
# AZURE_OPENAI_FAILOVER_DEPLOYMENT=gpt-4

# ============================================
# Alternative: OpenAI (instead of Azure)
# ============================================
# Uncomment if using OpenAI instead of Azure OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ============================================
# Vector Database (Local ChromaDB)
# ============================================
# Local ChromaDB storage directory
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag-demo-local

# ============================================
# Application Settings
# ============================================
# Logging
LOG_LEVEL=INFO

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_SIZE=10485760  # 10 MB

# RAG Settings
DEFAULT_N_RESULTS=5
MAX_N_RESULTS=10

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
RELOAD=true  # Auto-reload on code changes (development only)

# ============================================
# CORS Configuration (for Electron UI)
# ============================================
CORS_ORIGINS=*  # Allow all origins in development
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # Production

# ============================================
# Optional: AWS Configuration (for AWS mode)
# ============================================
# Only needed if USE_S3_UPLOAD=true or USE_SSM_CONFIG=true
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# DYNAMODB_CONFIG_TABLE=rag-demo-config
# DYNAMODB_DOCUMENTS_TABLE=rag-demo-documents

