# Azure OpenAI - Primary Subscription (Chat Model) - US East
AZURE_OPENAI_ENDPOINT_1=https://my-openai-us-east-1.openai.azure.com/
AZURE_OPENAI_KEY_1=your-us-east-key-here
AZURE_OPENAI_DEPLOYMENT_1=gpt-4o

# Azure OpenAI - Failover Subscription (Chat Model) - EU West
AZURE_OPENAI_ENDPOINT_2=https://my-openai-eu-west-1.openai.azure.com/
AZURE_OPENAI_KEY_2=your-eu-west-key-here
AZURE_OPENAI_DEPLOYMENT_2=gpt-4o

# Azure OpenAI - Embedding Model (US East)
AZURE_OPENAI_EMBEDDING_ENDPOINT_1=https://my-openai-us-east-1.openai.azure.com/
AZURE_OPENAI_EMBEDDING_KEY_1=your-us-east-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_1=text-embedding-3-small

# Azure OpenAI - Embedding Model (EU West)
AZURE_OPENAI_EMBEDDING_ENDPOINT_2=https://my-openai-eu-west-1.openai.azure.com/
AZURE_OPENAI_EMBEDDING_KEY_2=your-eu-west-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_2=text-embedding-3-small

# ============================================
# DynamoDB Configuration (Optional)
# ============================================
# Set USE_DYNAMODB_CONFIG=true to load configs from DynamoDB instead of env vars
USE_DYNAMODB_CONFIG=false
DYNAMODB_CONFIG_TABLE=rag-demo-config

# ============================================
# AWS SSM Parameter Store (Recommended for Production)
# ============================================
# Set USE_SSM_CONFIG=true to load Azure keys from SSM Parameter Store
# SSM is more secure than env vars or DynamoDB for storing secrets
USE_SSM_CONFIG=false
APP_NAME=rag-demo
AWS_REGION=us-east-1

# SSM Parameters will be loaded from:
# /${APP_NAME}/azure-openai/us-east/endpoint
# /${APP_NAME}/azure-openai/us-east/api-key (SecureString)
# /${APP_NAME}/azure-openai/us-east/deployment
# /${APP_NAME}/azure-openai/eu-west/endpoint
# /${APP_NAME}/azure-openai/eu-west/api-key (SecureString)
# /${APP_NAME}/azure-openai/eu-west/deployment

# Vector Database
USE_PINECONE=false
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (if USE_PINECONE=true)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=rag-demo

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
