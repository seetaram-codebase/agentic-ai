# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=971778147952
APP_NAME=rag-demo

# AWS S3
S3_BUCKET=rag-demo-documents-971778147952
USE_S3_UPLOAD=true  # Enable async processing via S3 + Lambda

# AWS DynamoDB
DYNAMODB_CONFIG_TABLE=rag-demo-config
DYNAMODB_DOCUMENTS_TABLE=rag-demo-documents

# AWS SQS
SQS_CHUNKING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/971778147952/rag-demo-document-chunking
SQS_EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/971778147952/rag-demo-document-embedding

# ============================================
# Configuration Mode
# ============================================
# Use SSM Parameter Store for secrets (recommended for production)
USE_SSM_CONFIG=true

# Or use DynamoDB for config (alternative)
USE_DYNAMODB_CONFIG=false

# ============================================
# Azure OpenAI Configuration
# Only needed if USE_SSM_CONFIG=false
# Otherwise, these are stored in AWS SSM Parameter Store
# ============================================

# Primary Azure OpenAI (US East)
AZURE_OPENAI_ENDPOINT_1=https://your-openai-us-east.openai.azure.com/
AZURE_OPENAI_KEY_1=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_1=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Secondary Azure OpenAI (EU West - Failover)
AZURE_OPENAI_ENDPOINT_2=https://your-openai-eu-west.openai.azure.com/
AZURE_OPENAI_KEY_2=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_2=gpt-4o-mini

# Embedding Configuration
AZURE_EMBEDDING_ENDPOINT_1=https://your-openai-us-east.openai.azure.com/
AZURE_EMBEDDING_KEY_1=your-api-key-here
AZURE_EMBEDDING_DEPLOYMENT_1=text-embedding-ada-002

AZURE_EMBEDDING_ENDPOINT_2=https://your-openai-eu-west.openai.azure.com/
AZURE_EMBEDDING_KEY_2=your-api-key-here
AZURE_EMBEDDING_DEPLOYMENT_2=text-embedding-ada-002

# ============================================
# Vector Store Configuration
# ============================================
# Use Chroma (local/embedded) or Pinecone (cloud)
VECTOR_STORE=chroma  # Options: chroma, pinecone

# Chroma Configuration (for local development)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag-documents

# Pinecone Configuration (for production)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=rag-demo

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=dev
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Testing
# ============================================
RUN_AWS_TESTS=0
RUN_E2E_TESTS=0

